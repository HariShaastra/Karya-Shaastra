rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, email, displayName, photoURL, role
    //
    // Collection: initiatives
    // Fields: id, ownerId, name, type, problemStatement, targetGroup, proposedSolution, why, expectedOutcome, stage, createdAt
    //
    // Sub-collection: initiatives/{initiativeId}/actions
    // Fields: id, initiativeId, userId, description, category, timeSpent, notes, timestamp, proofUrl, proofType
    //
    // Sub-collection: initiatives/{initiativeId}/team
    // Fields: id, initiativeId, userId, email, role, invitedAt, joinedAt
    //
    // Sub-collection: initiatives/{initiativeId}/resources
    // Fields: id, initiativeId, type, amount, description, timestamp
    //
    // Sub-collection: initiatives/{initiativeId}/milestones
    // Fields: id, initiativeId, title, description, completed, completedAt
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isInitiativeOwner(initiativeId) {
      return isAuthenticated() && get(/databases/$(database)/documents/initiatives/$(initiativeId)).data.ownerId == request.auth.uid;
    }

    function isTeamMember(initiativeId) {
      return isAuthenticated() && (
        isInitiativeOwner(initiativeId) ||
        exists(/databases/$(database)/documents/initiatives/$(initiativeId)/team/$(request.auth.uid))
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             data.email.size() < 256;
    }

    function isValidInitiative(data) {
      return data.keys().hasAll(['id', 'ownerId', 'name', 'type']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.type in ['profit', 'non-profit', 'community'];
    }

    function isValidAction(data) {
      return data.keys().hasAll(['id', 'initiativeId', 'userId', 'description', 'category', 'timestamp']) &&
             data.description is string && data.description.size() > 0 && data.description.size() < 1000 &&
             data.category in ['outreach', 'operations', 'finance', 'content', 'other'];
    }

    function isValidTeamMember(data) {
      return data.keys().hasAll(['id', 'initiativeId', 'email', 'role']) &&
             data.role in ['founder', 'volunteer', 'partner'];
    }

    function isValidResource(data) {
      return data.keys().hasAll(['id', 'initiativeId', 'type', 'amount', 'timestamp']) &&
             data.type in ['in', 'out'] &&
             data.amount is number;
    }

    function isValidMilestone(data) {
      return data.keys().hasAll(['id', 'initiativeId', 'title']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /initiatives/{initiativeId} {
      allow read: if true; // Public profiles
      allow create: if isAuthenticated() && isValidInitiative(request.resource.data) && request.resource.data.ownerId == request.auth.uid;
      allow update: if isInitiativeOwner(initiativeId) && isValidInitiative(request.resource.data);
      allow delete: if isInitiativeOwner(initiativeId);

      match /actions/{actionId} {
        allow read: if true; // Public proof of work
        allow create: if isTeamMember(initiativeId) && isValidAction(request.resource.data) && request.resource.data.userId == request.auth.uid;
        allow update: if isTeamMember(initiativeId) && isValidAction(request.resource.data) && (resource.data.userId == request.auth.uid || isInitiativeOwner(initiativeId));
        allow delete: if isTeamMember(initiativeId) && (resource.data.userId == request.auth.uid || isInitiativeOwner(initiativeId));
      }

      match /team/{memberId} {
        allow read: if isTeamMember(initiativeId); // Keep emails private
        allow create, update, delete: if isInitiativeOwner(initiativeId) && isValidTeamMember(request.resource.data);
      }

      match /resources/{resourceId} {
        allow read: if isTeamMember(initiativeId);
        allow create, update, delete: if isTeamMember(initiativeId) && isValidResource(request.resource.data);
      }

      match /milestones/{milestoneId} {
        allow read: if true; // Public progress
        allow create, update, delete: if isTeamMember(initiativeId) && isValidMilestone(request.resource.data);
      }
    }
  }
}
